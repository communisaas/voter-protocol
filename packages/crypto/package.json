{
  "name": "@voter-protocol/crypto",
  "version": "0.1.3",
  "description": "Cryptography library for VOTER Protocol - compression, encryption, key derivation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "noir/fixtures/target/*.json",
    "noir/sponge_helper/target/*.json",
    "noir/district_membership/target/*.json",
    "noir/two_tree_membership/target/*.json",
    "noir/three_tree_membership/target/*.json"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./poseidon2": "./dist/poseidon2.js",
    "./engagement": "./dist/engagement.js",
    "./district-prover": "./dist/district-prover.js",
    "./circuits": "./dist/circuits/pkg/index.js",
    "./noir-fixtures": "./noir/fixtures/target/fixtures.json",
    "./noir-sponge-helper": "./noir/sponge_helper/target/sponge_helper.json",
    "./circuits/district_membership_18": "./noir/district_membership/target/district_membership_18.json",
    "./circuits/district_membership_20": "./noir/district_membership/target/district_membership_20.json",
    "./circuits/district_membership_22": "./noir/district_membership/target/district_membership_22.json",
    "./circuits/district_membership_24": "./noir/district_membership/target/district_membership_24.json",
    "./circuits/three-tree-18": "./noir/three_tree_membership/target/three_tree_membership_18.json",
    "./circuits/three-tree-20": "./noir/three_tree_membership/target/three_tree_membership_20.json",
    "./circuits/three-tree-22": "./noir/three_tree_membership/target/three_tree_membership_22.json",
    "./circuits/three-tree-24": "./noir/three_tree_membership/target/three_tree_membership_24.json",
    "./circuits/two-tree-18": "./noir/two_tree_membership/target/two_tree_membership_18.json",
    "./circuits/two-tree-20": "./noir/two_tree_membership/target/two_tree_membership_20.json",
    "./circuits/two-tree-22": "./noir/two_tree_membership/target/two_tree_membership_22.json",
    "./circuits/two-tree-24": "./noir/two_tree_membership/target/two_tree_membership_24.json"
  },
  "scripts": {
    "build": "tsc",
    "build:circuits": "./scripts/build-circuits.sh",
    "build:two-tree-circuits": "./scripts/build-two-tree-circuits.sh",
    "test": "vitest",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@aztec/bb.js": "2.1.8",
    "@noir-lang/noir_js": "1.0.0-beta.16"
  },
  "devDependencies": {
    "@types/node": "^24.3.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "voter-protocol",
    "encryption",
    "compression",
    "zk",
    "near"
  ],
  "author": "VOTER Protocol",
  "license": "MIT"
}
