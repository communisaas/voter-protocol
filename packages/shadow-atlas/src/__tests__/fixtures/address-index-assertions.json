{
  "version": 1,
  "schema": "atlas-address-index-assertions",
  "contract": "SEAM-CONTRACT v1 §6",
  "normVersion": 1,
  "states": [
    "DE",
    "RI",
    "DC"
  ],
  "verification": "Every non-miss entry is a real address whose expected coordinates were computed by an independent re-implementation of the §2 match ladder over the published sample chunks; picks were additionally spot-checked against known landmark locations (White House, US Supreme Court, RI State House, The Breakers, Corporation Trust Center, Legislative Hall). MUST-MISS entries must return no result — a miss is never converted to a fabricated coordinate.",
  "assertions": [
    {
      "label": "White House — exact NAD point (src:0)",
      "covers": [
        "point"
      ],
      "input": {
        "street": "1600 Pennsylvania Ave NW",
        "city": "Washington",
        "state": "DC",
        "postalcode": "20500"
      },
      "expect": {
        "matchClass": "point",
        "lat": 38.89768,
        "lng": -77.03655,
        "tolDeg": 0.0001
      }
    },
    {
      "label": "White House — long-form directional + suffix normalize to the same point",
      "covers": [
        "point",
        "directional",
        "suffix"
      ],
      "input": {
        "street": "1600 Pennsylvania Avenue Northwest",
        "city": "Washington",
        "state": "DC",
        "postalcode": "20500"
      },
      "expect": {
        "matchClass": "point",
        "lat": 38.89768,
        "lng": -77.03655,
        "tolDeg": 0.0001
      }
    },
    {
      "label": "US DOJ — punctuated \"Ave. N.W.\" normalizes to the same street key",
      "covers": [
        "point",
        "directional",
        "suffix"
      ],
      "input": {
        "street": "950 Pennsylvania Ave. N.W.",
        "city": "Washington",
        "state": "DC",
        "postalcode": "20530"
      },
      "expect": {
        "matchClass": "point",
        "lat": 38.89365,
        "lng": -77.02505,
        "tolDeg": 0.0001
      }
    },
    {
      "label": "Old Post Office — trailing \"Suite 200\" stripped, never enters the street key",
      "covers": [
        "point",
        "unit-strip"
      ],
      "input": {
        "street": "1100 Pennsylvania Avenue NW Suite 200",
        "city": "Washington",
        "state": "DC",
        "postalcode": "20004"
      },
      "expect": {
        "matchClass": "point",
        "lat": 38.89413,
        "lng": -77.02757,
        "tolDeg": 0.0001
      }
    },
    {
