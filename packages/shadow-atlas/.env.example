# Shadow Atlas Environment Configuration
# Copy to .env and fill in values

# ─────────────────────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────────────────────

# HTTP server port (default: 3000)
PORT=3000

# Bind address (use 0.0.0.0 for Docker, 127.0.0.1 for local dev)
HOST=0.0.0.0

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

# SQLite database path (persistent storage)
DB_PATH=/data/shadow-atlas.db

# ─────────────────────────────────────────────────────────────
# IPFS (Insertion Log Persistence)
# ─────────────────────────────────────────────────────────────

# IPFS gateway for log recovery (default: https://w3s.link)
IPFS_GATEWAY=https://w3s.link

# Storacha (formerly Web3.Storage) pinning service
# Get credentials from https://console.web3.storage
STORACHA_SPACE_DID=
STORACHA_AGENT_KEY=
STORACHA_PROOF=

# ─────────────────────────────────────────────────────────────
# Cloudflare R2 (primary content distribution — upload-to-r2.ts)
# ─────────────────────────────────────────────────────────────
# Create R2 API tokens at: CF Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shadow-atlas
R2_PUBLIC_URL=https://atlas.commons.email

# ─────────────────────────────────────────────────────────────
# Cloudflare Pages (push-cids.ts — sets env vars on Pages project)
# ─────────────────────────────────────────────────────────────
# API token needs Pages:Edit permission
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CF_PAGES_PROJECT=commons
ATLAS_BASE_URL=https://atlas.commons.email

# Lighthouse perpetual IPFS pinning
# Get API key from https://lighthouse.storage
LIGHTHOUSE_API_KEY=

# ─────────────────────────────────────────────────────────────
# Redistricting Data Hub API (Optional)
# Required only for VTD extraction pipeline
# ─────────────────────────────────────────────────────────────

# RDH API credentials (get from https://redistrictingdatahub.org)
RDH_USERNAME=
RDH_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Ed25519 Signing (Verifiable Solo Operator)
# ─────────────────────────────────────────────────────────────

# Path to Ed25519 PEM key file (REQUIRED in production)
# If not set, an ephemeral key is generated (receipts lost on restart)
SIGNING_KEY_PATH=

# ─────────────────────────────────────────────────────────────
# API Security
# ─────────────────────────────────────────────────────────────

# Bearer token for POST /v1/register (REQUIRED in production — CR-004)
# Prevents tree-filling attacks. Server fails closed if missing in production.
REGISTRATION_AUTH_TOKEN=

# Bearer token for GET /v1/metrics (recommended for production)
METRICS_AUTH_TOKEN=

# ─────────────────────────────────────────────────────────────
# API Configuration
# ─────────────────────────────────────────────────────────────

# CORS allowed origins (comma-separated)
# REQUIRED: Set to your actual frontend origin(s)
# SECURITY: Never use * in production! Explicitly list allowed origins.
# Example for production: CORS_ORIGINS=https://app.voter-protocol.org,https://staging.voter-protocol.org
# Example for local dev: CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGINS=https://your-app.example.com

# Rate limit per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Require API key for requests (set to true for production)
API_KEY_REQUIRED=false

# ─────────────────────────────────────────────────────────────
# Tree 2 (Cell-District Map)
# ─────────────────────────────────────────────────────────────

# Path to pre-built tree2-snapshot.json (fast startup, recommended for production)
CELL_MAP_SNAPSHOT=

# Build Tree 2 from Census BAFs on startup (use for dev/single-state testing)
# Set to a 2-digit FIPS code (e.g. "06" for CA) or "all" for all states
CELL_MAP_STATE=

# Directory for cached BAF downloads (default: data/baf-cache)
BAF_CACHE_DIR=data/baf-cache

# ─────────────────────────────────────────────────────────────
# Persistent State
# ─────────────────────────────────────────────────────────────

# Directory for insertion log, IPFS metadata, and other persistent state
DATA_DIR=/data/shadow-atlas

# ─────────────────────────────────────────────────────────────
# Officials Data (Pre-Ingested Congress Members)
# ─────────────────────────────────────────────────────────────

# SQLite database with federal/state legislators (populated by ingest-legislators.ts)
# Default: ${DATA_DIR}/officials.db
# OFFICIALS_DB_PATH=/data/shadow-atlas/officials.db

# ─────────────────────────────────────────────────────────────
# Engagement Pipeline (Three-Tree Architecture)
# Required for three-tree proofs (the primary proof path).
# Tree 3 (Engagement) tracks on-chain activity and computes
# engagement tiers for ThreeTreeMembership proofs.
# ─────────────────────────────────────────────────────────────

# Scroll RPC endpoint (REQUIRED for three-tree — enables chain event scanner)
CHAIN_RPC_URL=https://rpc.scroll.io

# DistrictGate contract address (REQUIRED — emits proof verification events)
DISTRICT_GATE_ADDRESS=0x...

# Block number to start scanning from (default: contract deployment block)
CHAIN_START_BLOCK=0

# Poll interval in milliseconds (default: 30000 for L2)
CHAIN_POLL_INTERVAL_MS=30000

# Path to action category registry JSON file (RECOMMENDED)
# Maps action domain hashes to category IDs (1-5) for Shannon diversity scoring.
# Without this, diversityScore will be 0 for all identities.
ACTION_CATEGORY_REGISTRY=data/action-categories.json

# ─────────────────────────────────────────────────────────────
# Debate Market Relayer + Epoch Keeper
# Submits user trades on-chain and auto-executes epochs.
# All three vars are required to enable the relayer.
# Without RELAYER_PRIVATE_KEY the service starts but users must
# submit trades directly to the contract.
# ─────────────────────────────────────────────────────────────

# Relayer wallet private key (hex, 0x-prefixed)
# WARNING: this key must hold ETH for gas on the target chain
# RELAYER_PRIVATE_KEY=0x...

# DebateMarket contract address
# DEBATE_MARKET_ADDRESS=0x...

# Chain ID: 534351 = Scroll Sepolia, 534352 = Scroll mainnet
# CHAIN_ID=534351

# ─────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────

# Enable network tests (default: false, skipped in CI)
RUN_NETWORK_TESTS=false

# Enable integration tests
RUN_INTEGRATION=false

# Enable E2E tests
RUN_E2E=false
